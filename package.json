{
  "name": "dynamic-packaging",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "物品动态装箱展示系统 (monorepo: 装箱前端 / 管理后台 / 共享契约)",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:packing": "pnpm --filter packing-web dev",
    "dev:admin": "pnpm --filter admin-web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
